  <td></td>
<th>Immediate</th>
<th>Non-immediate</th> </tr> </thead>
<tbody>
<tr>
<th><em>Relation of ideas</em></th>
  <td>Intuition</td>
  <td>Demonstrative arguments</td> </tr>
<tr>
<th><em>Matters of fact</em></th>
  <td>Sensation</td>
  <td>Probable arguments</td> </tr> </tbody>
