            var id = player.id.slice(8);
            if (window['videoPlayer' + id] && typeof window['videoPlayer' + id].pauseVideo === 'function') {
                window['videoPlayer' + id].pauseVideo();
            }
        });

        var videoElement = document.getElementById('youtube-' + videoId);
        if (videoElement) {
            videoElement.classList.remove('hidden');
        }

        if (window['videoPlayer' + videoId] && typeof window['videoPlayer' + videoId].playVideo === 'function') {
            window['videoPlayer' + videoId].playVideo();
        }
    }

    function hideConsentMessages() {
        var consentMessages = document.querySelectorAll("[data-id='sf-youtube-message']:not(.hidden)");
        consentMessages.forEach(function (message) {
            message.classList.add('hidden');
        });
    }

    function showConsentMessages() {
        var consentMessages = document.querySelectorAll("[data-id='sf-youtube-message'].hidden");
        consentMessages.forEach(function (message) {
            message.classList.remove('hidden');
        });
    }

    function showCoverImages() {
        var coverImages = document.querySelectorAll("[data-role='cover-image'].hidden");
        coverImages.forEach(function (cover) {
            cover.classList.remove('hidden');
        });

        // Also restore cover text visibility
        var coverTexts = document.querySelectorAll("[data-role='cover-text']");
        coverTexts.forEach(function (text) {
            text.dataset.hidden = 'false';
        });

        // Hide the YouTube iframes to prevent native clicks from playing
        var players = document.querySelectorAll('iframe[id^="youtube-"]');
        players.forEach(function (player) {
            player.classList.add('hidden');
        });
    }

    function pauseAllVideos() {
        Object.keys(window).forEach(function (key) {
            if (key.startsWith('videoPlayer') && window[key] && typeof window[key].pauseVideo === 'function') {
                window[key].pauseVideo();
            }
        });
    }

    function checkForConsentMessages() {
        var consentMessages = document.querySelectorAll("[data-id='sf-youtube-message']:not(.hidden)");
        if (consentMessages.length > 0 && window.sfPrivacyConsent && window.sfPrivacyConsent.hasConsent()) {
            hideConsentMessages();
        }
    }

    function handlePlayButtonClick(e) {
        var playButton = e.target.closest('[data-video-function="play"]');
        if (!playButton) return;

        var videoId = playButton.dataset.id;
        if (!videoId) return;

        e.preventDefault();

        if (window.sfPrivacyConsent && window.sfPrivacyConsent.hasConsent()) {
            if (youtubeApiLoaded && window['videoPlayer' + videoId]) {
                playVideo(videoId);
            } else {
                pendingVideoId = videoId;
                loadYouTubeAPI(function () {
                    if (window['videoPlayer' + videoId]) {
                        playVideo(videoId);
                    }
                });
            }
            return;
        }

        if (window.sfPrivacyConsent) {
            pendingVideoId = videoId;
            window.sfPrivacyConsent.grantConsent();
        }
    }

    function init() {
        document.addEventListener('click', handlePlayButtonClick);

        if (window.sfPrivacyConsent && window.sfPrivacyConsent.hasConsent()) {
            loadYouTubeAPI();
        }

        document.addEventListener('sf-consent-changed', function (e) {
            if (e.detail && e.detail.hasConsent) {
                // If API already loaded and player exists, play immediately else loadYouTubeAPI will trigger createPlayers which has onReady to play pendingVideoId
                if (youtubeApiLoaded && pendingVideoId && window['videoPlayer' + pendingVideoId]) {
                    playVideo(pendingVideoId);
                    pendingVideoId = null;
                } else {
                    loadYouTubeAPI();
                }
                hideConsentMessages();
            } else {
                pauseAllVideos();
                showConsentMessages();
                showCoverImages();
            }
        });

        checkForConsentMessages();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
