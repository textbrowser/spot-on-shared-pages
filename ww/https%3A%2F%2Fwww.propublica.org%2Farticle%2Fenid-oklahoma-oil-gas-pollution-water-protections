        function metersToFeet(m) {
            return Math.round(m * 3.28084).toLocaleString();
        }

        function pluralize(n, singular, plural) {
            return n === 1
                ? singular
                : plural !== undefined
                  ? plural
                  : singular + "s";
        }

        function tmpl(str, ctx) {
            const keys = Object.keys(ctx);
            const vals = Object.values(ctx);
            return str.replace(/\{\{(.+?)\}\}/g, (_, expr) =>
                new Function(...keys, `return ${expr}`)(...vals),
            );
        }

        function hideAnnotation() {
            if (!annotationVisible) return;
            document.getElementById("swoopy-svg").style.display = "none";
            annotationVisible = false;
        }

        function positionAnnotation() {
            if (!annotationTargetLngLat) return;
            const pt = map.project(annotationTargetLngLat);
            const labelW = 190,
                labelH = 80;
            const lx = pt.x - labelW - 18;
            const ly = Math.max(8, pt.y - labelH - 12);
            // Origin: right edge + 14px horizontal buffer, at vertical midpoint
            const originX = lx + labelW + 14;
            const originY = ly + labelH / 2;
            // Control point to the RIGHT of the origin→endpoint line for outward curve
            const cx = pt.x + 60,
                cy = pt.y - 35;
            // Back arrowhead off 10px from well along the final tangent direction
            const dx = pt.x - cx,
                dy = pt.y - cy;
            const len = Math.sqrt(dx * dx + dy * dy);
            const endX = pt.x - (dx / len) * 18;
            const endY = pt.y - (dy / len) * 18;
            document.getElementById("swoopy-fo").setAttribute("x", lx - 6);
            document.getElementById("swoopy-fo").setAttribute("y", ly - 6);
            document
                .getElementById("swoopy-path")
                .setAttribute(
                    "d",
                    `M ${originX} ${originY} Q ${cx} ${cy} ${endX} ${endY}`,
                );
        }

        window.addEventListener("resize", () => {
            if (annotationVisible) positionAnnotation();
        });

        map.on("load", async () => {
            [pwsPolygons, wellPairs] = await Promise.all([
                fetch(
