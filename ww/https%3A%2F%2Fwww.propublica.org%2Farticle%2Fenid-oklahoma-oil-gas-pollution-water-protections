            map.addLayer({
                id: "wells-pws",
                type: "circle",
                source: "well-pairs",
                filter: [
                    "all",
                    ["==", ["get", "well_type"], "pws"],
                    [">", ["coalesce", ["get", "distance_meters"], -1], 0],
                ],
                layout: { visibility: "none" },
                paint: {
                    "circle-color": COLOR_PWS,
                    "circle-radius": 4,
                    "circle-stroke-color": haloColor,
                    "circle-stroke-width": 1,
