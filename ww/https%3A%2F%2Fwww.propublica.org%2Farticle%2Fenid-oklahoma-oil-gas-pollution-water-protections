        function setupLayersAndInteractions() {
            if (!pwsPolygons || !wellPairs) return;
            if (map.getSource("pws-areas")) return;
            const haloColor = getIsDark() ? "#000000" : "#888888";
            createUICSquareImage("uic-square", 12, haloColor);
            createUICSquareImage("uic-square-cluster", 22, haloColor);
            // Find the lowest label layer in the base style so PWS polygon layers sit beneath city/state/region text.
            const firstLabelLayer = map
                .getStyle()
                .layers.find(
                    (l) =>
                        l.type === "symbol" &&
                        l.layout &&
                        l.layout["text-field"],
                );
            const beforeLabelId = firstLabelLayer
                ? firstLabelLayer.id
                : undefined;
            map.addSource("pws-areas", { type: "geojson", data: pwsPolygons });
            map.addLayer(
                {
                    id: "pws-fill",
                    type: "fill",
                    source: "pws-areas",
                    paint: { "fill-color": "#dceeff", "fill-opacity": 0.7 },
                },
                beforeLabelId,
            );
            map.addLayer(
                {
                    id: "pws-outline",
                    type: "line",
                    source: "pws-areas",
                    paint: {
                        "line-color": COLOR_PWS,
                        "line-width": 1,
                        "line-opacity": 0.3,
                    },
                },
                beforeLabelId,
            );
            map.addLayer(
                {
                    id: "pws-fill-active",
                    type: "fill",
                    source: "pws-areas",
                    filter: ["==", ["get", "pws_pwsid"], ""],
                    paint: { "fill-color": "#ffeda1", "fill-opacity": 0.5 },
                },
                beforeLabelId,
            );

            map.addSource("well-pairs", { type: "geojson", data: wellPairs });

            // Layer order (lowest → highest): nonproximal PWS, proximal PWS, UIC clusters/points
            map.addLayer({
                id: "wells-pws-dim",
                type: "circle",
                source: "well-pairs",
                filter: [
                    "all",
                    ["==", ["get", "well_type"], "pws"],
                    [
                        "!",
                        [">", ["coalesce", ["get", "distance_meters"], -1], 0],
                    ],
                ],
                layout: { visibility: "none" },
                paint: {
                    "circle-color": COLOR_PWS_DIM,
